{
  "name": "@jamieblair/wind-site-intelligence-core",
  "version": "0.1.0",
  "description": "Core scoring engine for wind turbine site suitability analysis",
  "author": "Jamie Blair <jamie@jamieblair.co.uk>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "tsc --noEmit",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
