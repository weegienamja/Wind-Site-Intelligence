{
  "name": "@jamieblair/windforge",
  "version": "0.3.0",
  "description": "React components for wind energy site assessment and visualisation",
  "author": "Jamie Blair <jamie@jamieblair.co.uk>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "tsc --noEmit",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@jamieblair/windforge-core": "workspace:*",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
